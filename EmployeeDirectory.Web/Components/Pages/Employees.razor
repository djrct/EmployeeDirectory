@page "/employees"
@using EmployeeDirectory.Shared.DTOs
@using EmployeeDirectory.Web.Clients
@inject IEmployeeApiClient EmployeeApiClient

<PageTitle>Employees</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Employees</h1>

    <a class="btn btn-primary" href="/employees/create">
        Add employee
    </a>
</div>

@if (_isLoading)
{
    <p>Loading employees...</p>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}
else if (_employees.Count == 0)
{
    <p>No employees were found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Title</th>
                <th>Location</th>
                <th>Email</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in _employees)
            {
                <tr>
                    <td>
                        <a href="/employees/@employee.Id">
                            @employee.FirstName @employee.LastName
                        </a>
                    </td>
                    <td>@employee.Department</td>
                    <td>@employee.Title</td>
                    <td>@employee.Location</td>
                    <td>
                        <a href="mailto:@employee.Email">
                            @employee.Email
                        </a>
                    </td>
                    <td>@(employee.IsActive ? "Active" : "Inactive")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<EmployeeDto> _employees = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _employees = await EmployeeApiClient.GetEmployeesAsync();
        }
        catch (HttpRequestException)
        {
            _errorMessage =
                "The employee directory could not be loaded. Confirm that the API is running.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
