@page "/employees/{Id:int}"
@using EmployeeDirectory.Shared.DTOs
@using EmployeeDirectory.Web.Clients
@inject IEmployeeApiClient EmployeeApiClient

<h3>EmployeeDetails</h3>

@if (_isLoading)
{
    <p>Loading employee details...</p>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}
else if (_employee is null)
{
    <p>No employee details were found.</p>
}
else
{
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">
                @_employee.FirstName @_employee.LastName
            </h4>

            <dl class="row mt-4">
                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@_employee.Department</dd>

                <dt class="col-sm-3">Title</dt>
                <dd class="col-sm-9">@_employee.Title</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@_employee.Location</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">
                    <a href="mailto:@_employee.Email">
                        @_employee.Email
                    </a>
                </dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@_employee.PhoneNumber</dd>

                <dt class="col-sm-3">Hire Date</dt>
                <dd class="col-sm-9">@_employee.HireDate.ToString("MM/dd/yyyy")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (_employee.IsActive)
                    {
                        <span class="badge text-bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Inactive</span>
                    }
                </dd>
            </dl>

            <a class="btn btn-outline-secondary" href="/employees">
                Back to employees
            </a>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private string? _errorMessage;
    private EmployeeDto? _employee;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _employee = null;

        try
        {
            _employee = await EmployeeApiClient.GetEmployeeAsync(Id);
        }
        catch (HttpRequestException)
        {
            _errorMessage =
                "The employee detail could not be loaded. Confirm that the API is running.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
